# CiteGuard configuration — copy to `.env` and fill in. NEVER commit real secrets.
# (`.env` is gitignored; only this template is tracked.)

# --- Required: language model (Anthropic / Claude) -------------------------
# CiteGuard drives Claude through the official Anthropic SDK.
ANTHROPIC_API_KEY=

# --- Optional: model + endpoint overrides ---------------------------------
# Defaults to claude-opus-4-8 (see config.py). Override without editing code:
AGENT_MODEL=claude-opus-4-8
# Only set if routing Anthropic traffic through a proxy/gateway:
# ANTHROPIC_BASE_URL=

# --- Recommended: polite contact for scholarly APIs -----------------------
# Crossref / Unpaywall ask for a contact email (their "polite pool"). Unpaywall
# requires one. Use a real address you control.
UNPAYWALL_EMAIL=
# CROSSREF_MAILTO=            # falls back to UNPAYWALL_EMAIL if unset

# --- Optional: raise scholarly-API rate limits ----------------------------
# OPENALEX_API_KEY=           # free key (OpenAlex went metered in Feb 2026)
# NCBI_API_KEY=               # free NCBI key raises PubMed E-utilities limits

# --- A2A serving (used by `serve-handler` / deployment) -------------------
# AGENT_A2A_HOST=0.0.0.0
# AGENT_A2A_PORT=9110
# AGENT_A2A_URL=              # the publicly reachable JSON-RPC URL advertised in the card
